{
  "title": "Focus Ghostty tt window",
  "rules": [
    {
      "description": "Ctrl+Option+Cmd+T → Activate Ghostty and focus 'tt' window",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "t",
            "modifiers": {
              "mandatory": [
                "control",
                "option",
                "command"
              ]
            }
          },
          "to": [
            {
              "shell_command": "/Users/sglavoie/scripts/bin/.local/bin/focus-tt-ghostty.sh"
            }
          ]
        }
      ]
    }
  ]
}
