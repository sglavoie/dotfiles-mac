{
  "title": "Open Trail root",
  "rules": [
    {
      "description": "Ctrl+Option+Cmd+L → Run trail open --root",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "l",
            "modifiers": {
              "mandatory": [
                "control",
                "option",
                "command"
              ]
            }
          },
          "to": [
            {
              "shell_command": "PATH=/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin /Users/sglavoie/.local/bin/trail open --root"
            }
          ]
        }
      ]
    }
  ]
}
