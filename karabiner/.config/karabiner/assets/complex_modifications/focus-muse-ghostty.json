{
  "title": "Focus Ghostty muse window",
  "rules": [
    {
      "description": "Ctrl+Option+Cmd+M → Activate Ghostty and focus 'muse' window",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "m",
            "modifiers": {
              "mandatory": [
                "control",
                "option",
                "command"
              ]
            }
          },
          "to": [
            {
              "shell_command": "/bin/sh /Users/sglavoie/scripts/bin/.local/bin/focus-muse-ghostty.sh"
            }
          ]
        }
      ]
    }
  ]
}
