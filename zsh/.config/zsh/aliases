large-files() {
  if [[ "$1" == "--help" || "$1" == "-h" ]]; then
    echo "Usage: large-files [-u] [extension]"
    echo ""
    echo "Show the 10 largest files by line count."
    echo ""
    echo "Options:"
    echo "  -u          Include files ignored by .gitignore"
    echo "  -h, --help  Show this help message"
    echo ""
    echo "Examples:"
    echo "  large-files          All files"
    echo "  large-files md       Only .md files"
    echo "  large-files -u py    Only .py files, including ignored"
    return 0
  fi
  local unrestricted=""
  if [[ "$1" == "-u" ]]; then
    unrestricted="-u"
    shift
  fi
  local ext="${1:+-e $1}"
  fd --type f ${=unrestricted} ${=ext} --exec wc -l | sort -nr | head -n 10
}

