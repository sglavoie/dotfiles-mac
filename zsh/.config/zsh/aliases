# Open in Code
oc() {
  IFS=$'\n' files=($(fzf --query="$1" --multi --select-1 --exit-0))
  [[ -n "$files" ]] && code "${files[@]}"
}

# Open in Neovim
onvim() {
  IFS=$'\n' files=($(fzf --query="$1" --multi --select-1 --exit-0))
  [[ -n "$files" ]] && ${EDITOR:-vim} "${files[@]}"
}

# Open in Vim
ovim() {
  IFS=$'\n' files=($(fzf --query="$1" --multi --select-1 --exit-0))
  [[ -n "$files" ]] && vim "${files[@]}"
}

function killport() {
    lsof -i TCP:$1 | grep LISTEN | awk '{print $2}' | while read pid; do
        echo "Killing process with PID $pid listening on port $1"
        kill -9 "$pid"
    done
}

# Usage: sloc <extension>
# Example: sloc go
#          sloc py
sloc() {
  if [[ -z "$1" ]]; then
    echo "Usage: sloc <extension>"
    return 1
  fi

  find . -name "*.$1" \
  -not -path "*.venv*" \
  -not -name "*_pb2.py" \
  -not -path "*.ipynb_checkpoints*" \
  -not -path "*__pycache__*" | xargs wc -l
}

# Ignore specific files/directories in Dropbox
dropbox-ignore() {
    arg1=$1
    arg2=$2

    if [ -z "$arg1" ] || [ -z "$arg2" ]; then
        echo "Usage: dropbox-ignore <f|d> <name> (e.g. dropbox-ignore d .git)"
        return 1
    fi

    find ~/Dropbox -type $arg1 -name "$arg2" |
        xargs -I {} xattr -w com.dropbox.ignored 1 "{}"
}

# Sync specific files/directories in Dropbox
# that were previously ignored (or not)
dropbox-sync() {
    arg1=$1
    arg2=$2

    if [ -z "$arg1" ] || [ -z "$arg2" ]; then
        echo "Usage: dropbox-sync <f|d> <name> (e.g. dropbox-sync d .git)"
        return 1
    fi

    find ~/Dropbox -type $arg1 -name "$arg2" |
        xargs -I {} xattr -d com.dropbox.ignored "{}"
}
